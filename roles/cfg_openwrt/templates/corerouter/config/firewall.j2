#jinja2: trim_blocks: True, lstrip_blocks: True
{% import 'libraries/network.j2' as libnetwork with context %}
{% set l3_networks = networks | selectattr('assignments', 'defined') | selectattr('assignments', 'contains', inventory_hostname) | default([]) %}
{% set l3_mesh_networks = networks | selectattr('assignments', 'undefined') | selectattr('role', 'equalto', 'mesh') | default([]) %}
{% set query = "[].{name: name||role,inbound_filtering: inbound_filtering, direct_internet: direct_internet, freifunk_access: freifunk_access}" %}
{% set l3_networks = (l3_networks + l3_mesh_networks) | json_query(query) %}
{% set zone_freifunk_networks = l3_networks | rejectattr('inbound_filtering') | map(attribute='name') %}
{# Not scoped to inventory_hostname like l3_networks: uplink-role networks have no
   'assignments' to filter by (same pre-existing limitation as tunspace.j2's own
   uplink loop), so this assumes one corerouter per location owns all uplinks -
   true for every location today. A location with two corerouters sharing a
   networks: list, only one of which owns the pppoe line, needs that fixed here too. #}
{% set uplink_networks = networks | selectattr('role', 'equalto', 'uplink') | selectattr('uplink_proto', 'defined') | selectattr('uplink_proto', 'equalto', 'pppoe') | list %}

config defaults
	option synflood_protect '1'
	option input 'ACCEPT'
	option output 'ACCEPT'
	option forward 'REJECT'
	option drop_invalid '0'
{% if flow_offload=="sw" %}
	option flow_offloading '1'
{% elif flow_offload=="hw" %}
	option flow_offloading '1'
	option flow_offloading_hw '1'
{% endif %}

config zone 'zone_freifunk'
	option name 'freifunk'
	{% for name in zone_freifunk_networks %}
	list network '{{ name }}'
	{% endfor %}
	list device 'wg_+'
	list device 'ts_+'

{% if uplink_networks | length > 0 %}
config zone 'zone_wan'
	option name 'wan'
	{# This zone faces the raw internet, unlike zone_freifunk (mesh/tunnel, semi-trusted) -
	   reject unsolicited inbound instead of inheriting config defaults' input ACCEPT.
	   Locally-initiated traffic (DHCPv6-PD replies, etc.) still gets through via conntrack
	   established/related, same as the analogous zone in gateway/config/firewall.j2. #}
	option input 'REJECT'
	{# IPv4 has no real delegated space from the ISP, so it's masqueraded.
	   IPv6 uses a real routed/delegated prefix (see ip6assign/reqprefix in
	   network.j2), so it is NOT masqueraded - it's routed end-to-end. #}
	option masq '1'
	option mtu_fix '1'
	{% for u in uplink_networks %}
	list network '{{ libnetwork.getUciIfname(u) }}'
	list network '{{ libnetwork.getUciIfname(u) }}6'
	{% endfor %}

{% endif %}

{% for i in l3_networks | selectattr('inbound_filtering') %}
config zone 'zone_{{ i['name'] }}'
        option name '{{ i['name'] }}'
        list network '{{ i['name'] }}'

{% endfor %}
config forwarding
	option dest 'freifunk'
	option src 'freifunk'

{% for i in l3_networks | selectattr('inbound_filtering') %}
config forwarding
        option dest '{{ 'wan' if i.get('direct_internet') else 'freifunk' }}'
        option src '{{ i['name'] }}'

{% endfor %}

{# direct_internet networks are only forwarded to 'wan' above; opt into also
   reaching freifunk mesh resources (one-directional - freifunk still can't
   initiate into this network, same as everywhere else with inbound_filtering) #}
{% for i in l3_networks | selectattr('inbound_filtering') | selectattr('direct_internet') | selectattr('freifunk_access') %}
config forwarding
        option dest 'freifunk'
        option src '{{ i['name'] }}'

{% endfor %}

{% for i in l3_networks | selectattr('inbound_filtering') %}
# Allow essential forwarded IPv6 ICMP traffic
config rule
	option name		Allow-ICMPv6-Forward-{{ i['name'] }}
	option src		freifunk
	option dest		{{ i['name'] }}
	option proto		icmp
	list icmp_type		echo-request
	list icmp_type		echo-reply
	list icmp_type		destination-unreachable
	list icmp_type		packet-too-big
	list icmp_type		time-exceeded
	list icmp_type		bad-header
	list icmp_type		unknown-header-type
	option limit		1000/sec
	option family		ipv6
	option target		ACCEPT

{% endfor %}
