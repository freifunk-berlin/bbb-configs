        option prog     "/etc/librenms/wlRate.sh wlan2 rx min"
config extend
        option name     rate-rx-wlan2-avg
        option prog     "/etc/librenms/wlRate.sh wlan2 rx avg"
config extend
        option name     rate-rx-wlan2-max
        option prog     "/etc/librenms/wlRate.sh wlan2 rx max"
config extend
        option name     rate-rx-wlan5-min
        option prog     "/etc/librenms/wlRate.sh wlan5 rx min"
config extend
        option name     rate-rx-wlan5-avg
        option prog     "/etc/librenms/wlRate.sh wlan5 rx avg"
config extend
        option name     rate-rx-wlan5-max
        option prog     "/etc/librenms/wlRate.sh wlan5 rx max"
config extend
