config extend
        option name     snr-wlan2-avg
        option prog     "/etc/librenms/wlSNR.sh wlan2 avg"
config extend
        option name     snr-wlan2-max
        option prog     "/etc/librenms/wlSNR.sh wlan2 max"
config extend
        option name     snr-wlan5-min
        option prog     "/etc/librenms/wlSNR.sh wlan5 min"
config extend
        option name     snr-wlan5-avg
